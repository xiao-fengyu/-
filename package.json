{
  "name": "e-platform",
  "version": "1.0.0",
  "description": "AI\u9a71\u52a8\u7684\u5546\u54c1\u56fe\u7247\u751f\u6210 + \u591a\u5e73\u53f0\u4e00\u952e\u4e0a\u67b6\u684c\u9762\u5ba2\u6237\u7aef",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "server:dev": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"tsx watch server/index.ts\" \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:rebuild": "electron-rebuild",
    "electron:package": "npm run build && electron-builder",
    "electron:package:win": "npm run build && electron-builder --win --x64",
    "postinstall": "electron-rebuild"
  },
  "keywords": [],
  "author": {
    "name": "e-platform Team",
    "email": "admin@eplatform.app"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/form-data": "^2.5.2",
    "@types/multer": "^2.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "antd": "^5.23.0",
    "axios": "^1.16.1",
    "form-data": "^4.0.4",
    "better-sqlite3": "^11.7.0",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "sharp": "^0.33.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.0"
  }
}
